{
  "name": "example-rust",
  "version": "0.1.0",
  "binary": "./target/release/hairy-example-sidecar",
  "build_cmd": "cargo build --release",
  "tools": [
    {
      "name": "echo",
      "description": "Echo back the input text",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "required": ["text"]
      }
    },
    {
      "name": "hash_file",
      "description": "Compute SHA256 hash of a file",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": ["path"]
      }
    }
  ],
  "health_check": {
    "method": "health",
    "interval_ms": 30000
  },
  "resource_limits": {
    "max_memory_mb": 128,
    "timeout_ms": 10000
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@hairy/observability": ["packages/observability/src/index.ts"],
      "@hairy/core": ["packages/core/src/index.ts"],
      "@hairy/providers": ["packages/providers/src/index.ts"],
      "@hairy/channels": ["packages/channels/src/index.ts"],
      "@hairy/tools": ["packages/tools/src/index.ts"],
      "@hairy/memory": ["packages/memory/src/index.ts"],
      "@hairy/growth": ["packages/growth/src/index.ts"]
    }
  }
}
